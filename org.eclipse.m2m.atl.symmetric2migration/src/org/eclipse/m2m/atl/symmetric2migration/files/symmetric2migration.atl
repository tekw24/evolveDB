};
			
helper context Symmetric!SemanticChangeSet def :toSMO()
    : Migration!SchemaModificationOperator =
  if self.isResolvable() then thisModule.SemanticChangeSet2ResolvableSMO(self)
  else if self.isPartiallyResolvable() then thisModule.SemanticChangeSet2PartiallyResolvableSMO(self)
  else if self.isNotAutomaticallyResolvable() then thisModule.SemanticChangeSet2NotAutomaticallyResolvableSMO(self)
  else if self.isResolvableGraph() then thisModule.SemanticChangeSet2GraphResolvableSMO(self)
  else if self.isPartiallyResolvableGraph() then thisModule.SemanticChangeSet2GraphPartiallyResolvableSMO(self)
  else thisModule.SemanticChangeSet2GraphNotAutomaticallyResolvableSMO(self)
  endif endif endif endif endif;

